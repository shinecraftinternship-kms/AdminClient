{
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python"
    }
  },
  "outputDirectory": ".",
  "buildCommand": "echo done",
  "installCommand": "pip install -r requirements.txt",
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/admin/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index"
    }
  ]
}
